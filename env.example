# .env.local
# ─────────────────────────────────────────────────────────────
# 1. GROQ API KEY
#    → https://console.groq.com/keys
#    → Créez une clé API (gratuit, 14 400 req/jour sur Llama-3)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# 2. SUPABASE / PRISMA (PostgreSQL)
#    → https://supabase.com → New project → Settings → Database
#    DATABASE_URL  = Transaction pooler (port 6543) → pour Prisma runtime
#    DIRECT_URL    = Direct connection (port 5432)  → pour prisma db push / migrate
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# ─────────────────────────────────────────────────────────────
# 3. NEXTAUTH (optionnel – laisser vide si accès libre)
# NEXTAUTH_URL=https://votre-domaine.vercel.app
# NEXTAUTH_SECRET=votre-secret-32-caracteres-minimum
